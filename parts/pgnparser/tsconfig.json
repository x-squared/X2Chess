{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "typeRoots": ["../../frontend/node_modules/@types"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
