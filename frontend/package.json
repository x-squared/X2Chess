{
  "name": "x2chess-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5287 --strictPort",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx \"test/**/*.test.ts\" \"../parts/pgnparser/test/**/*.test.ts\" \"../parts/eco/test/**/*.test.ts\" \"../parts/boards/test/**/*.test.ts\" \"../parts/engines/test/**/*.test.ts\" \"../parts/resource/test/**/*.test.ts\"",
    "preview": "vite preview --port 5287 --strictPort",
    "desktop:dev": "tauri dev",
    "desktop:dev:isolated": "X2CHESS_WEBVIEW_DATA=../../run/DEV/webview-data tauri dev",
    "desktop:pack": "tauri build --ci false",
    "check:cycles": "madge --circular --extensions ts src/"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "chess.js": "^1.4.0",
    "chessground": "^9.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.5",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "madge": "^8.0.0",
    "ts-morph": "^27.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^7.0.0"
  }
}
