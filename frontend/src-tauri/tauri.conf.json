{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "X2Chess",
  "version": "0.0.1",
  "identifier": "com.x2chess.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5287",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "X2Chess",
        "width": 1400,
        "height": 1060,
        "minWidth": 980,
        "minHeight": 820,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5MkQxRTcxMEYzOEZGMUYKUldRZi96Z1BjUjR0aVZvZUpBb21JeXkvcWdXcFVQS1ZjME0wbHowY3QrRGZha1F4Q253MFhVU0UK",
      "endpoints": [
        "https://x-squared.github.io/X2Chess/latest.json"
      ],
      "dialog": false
    }
  }
}
